# =============================================================================
#  .gitignore for amore-bn254-cortex-m4
# =============================================================================

# ---- External dependencies (must NEVER be committed) ------------------------
# These are large external libraries that the user must install separately
# (see INSTALLATION.md). They are referenced via symlinks during local
# development.
# STM32CubeF4  # commented when promoted from symlink to submodule
relic_install
relic_build
relic/

# ---- Build artifacts --------------------------------------------------------
build/
*.elf
*.bin
*.hex
*.map
*.lst
*.o
*.obj
*.a
*.so

# ---- CMake ------------------------------------------------------------------
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
compile_commands.json

# ---- Editor / IDE -----------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---- Python -----------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.coverage
.tox/
.venv/
venv/

# ---- Logs and runtime output ------------------------------------------------
logs/
*.log
combined_report_*.txt
stm_report_*.txt
relic_report_*.txt

# ---- Backups and temporary files --------------------------------------------
*.bak
*.bak.*
*.before-*
*.tmp
.#*
\#*\#

# ---- OS / shell -------------------------------------------------------------
.bash_history
.zsh_history

# ---- Local config (optional, can be uncommented if needed) ------------------
# .env
# local_settings.sh
relic_install_bn254/

# Personal scratch files
1.sh

# Local backup of BN254 source files (also in git history)
backup_bn254/

# Host-side test binaries
tools/bls12_381_port/host_test/test_fp
tools/bls12_381_port/host_test/test_fp2
tools/bls12_381_port/host_test/test_fp12
tools/bls12_381_port/host_test/test_g

# Local drafts (PR responses, emails) — never commit
drafts/
EMAIL_TO_DIEGO*
PR_RESPONSE*
*.draft.txt
*.draft.md

# Compiled host test binaries (executable, no .c extension)
tools/bls12_381_port/host_test/test_fp12_bytes
tools/bls12_381_port/host_test/test_fp12_load
tools/bls12_381_port/host_test/test_gt_pow_q
relic_install_bn254/

# Workspace backup files (saved before major edits)
*.pre-*
*.bak.*
*.bak
